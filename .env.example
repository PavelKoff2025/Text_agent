# Скопируйте этот файл в .env и заполните значения

# === ОБЯЗАТЕЛЬНО (ProxyAPI) ===
# Для работы через ProxyAPI нужны два набора ключей (обычно отдельные).

# --- Обычная модель (OpenAI Chat Completions) ---
OPENAI_API_KEY=ваш-openai-ключ-от-proxyapi
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-4o-mini

# --- Думающая модель (Claude 4.5 Sonnet + reasoning) ---
ANTHROPIC_API_KEY=ваш-anthropic-ключ-от-proxyapi
ANTHROPIC_BASE_URL=https://api.proxyapi.ru/anthropic
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_THINKING_BUDGET=1500

# === ВАЖНО ДЛЯ РОССИИ И ДРУГИХ ЗАБЛОКИРОВАННЫХ РЕГИОНОВ ===
# Официальный OpenAI (api.openai.com) не работает из России и некоторых других стран.
# Укажите ниже адрес совместимого провайдера:

# --- Anthropic (Claude) через ProxyAPI.ru (по уроку) ---
# Мы работаем с ключом от proxyapi.ru

# 2. Настраиваем аналогично начальной конфигурации
ANTHROPIC_API_KEY=ваш-anthropic-ключ-от-proxyapi.ru
ANTHROPIC_BASE_URL=https://api.proxyapi.ru/anthropic

# 3. Указываем модель Claude 4.5 Sonnet (думающая версия)
ANTHROPIC_MODEL=claude-sonnet-4-5

# 4. Устанавливаем бюджет токенов для размышлений — 1500
ANTHROPIC_THINKING_BUDGET=1500

# В code это передаётся так:
# thinking = {"type": "enabled", "budget_tokens": 1500}

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=твой_токен_от_BotFather
# Получи у @BotFather в Telegram. Бот будет использовать ту же логику text_agent.py

# Для OpenAI (если нужно переключиться обратно):
# OPENAI_API_KEY=...
# OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
# OPENAI_MODEL=gpt-4o-mini

# --- Вариант 1: Groq (рекомендуется для тестов — бесплатно и очень быстро) ---
# 1. Зарегистрируйтесь: https://console.groq.com/keys
# 2. Создайте ключ и вставьте его в OPENAI_API_KEY выше
# 3. Раскомментируйте строку ниже:
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# Хорошие быстрые модели для Groq:
#   OPENAI_MODEL=llama-3.3-70b-versatile
#   OPENAI_MODEL=llama-3.1-8b-instant   (ещё быстрее)

# --- Вариант 2: OpenRouter (много моделей, в т.ч. почти как GPT) ---
# 1. Получите ключ: https://openrouter.ai/keys
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Примеры моделей:
#   OPENAI_MODEL=meta-llama/llama-3.1-70b-instruct
#   OPENAI_MODEL=openai/gpt-4o-mini   (если у вас есть доступ)

# --- Вариант 3: Ollama (запускаете модель локально на своём компьютере) ---
# 1. Установите Ollama: https://ollama.com
# 2. Скачайте модель: ollama pull llama3.2
# 3. Запустите сервер (обычно запускается автоматически)
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama          # для Ollama ключ можно любой
# OPENAI_MODEL=llama3.2

# --- Вариант 4: официальный OpenAI (работает только из поддерживаемых стран) ---
# OPENAI_BASE_URL=   (оставьте пустым или не указывайте)
# OPENAI_MODEL=gpt-4o-mini

# Дополнительно: можно явно задать модель для всех запусков
# OPENAI_MODEL=llama-3.3-70b-versatile

# Для вывода размышлений модели (как спрашивали на уроке) используй reasoning-модель:
# OPENAI_MODEL=o3-mini
# OPENAI_MODEL=o1
# OPENAI_MODEL=o1-mini
# OPENAI_MODEL=o4-mini   (если доступна у провайдера)

# ======================================================
# ANTHROPIC (Claude) — переход по уроку
# ======================================================
# 1. Получите ключ Anthropic на ProxyAPI.ru
# 2. Заполните ниже:

ANTHROPIC_API_KEY=ваш-anthropic-ключ-от-proxyapi.ru
ANTHROPIC_BASE_URL=https://api.proxyapi.ru/anthropic
ANTHROPIC_MODEL=claude-sonnet-4-5

# Для thinking (вывод размышлений модели, как на уроке):
# В text_agent.py используйте:
#   /thinking on
#   /thinking 800     ← бюджет токенов на размышления
#
# Пример вызова (как на скрине урока):
# client = anthropic.Anthropic(
#     api_key=ANTHROPIC_API_KEY,
#     base_url="https://api.proxyapi.ru/anthropic"
# )
# client.messages.create(
#     model="claude-sonnet-4-5",
#     thinking={"type": "enabled", "budget_tokens": 500},
#     messages=[{"role": "user", "content": [{"type": "text", "text": "..."}]}]
# )

# ======================================================
# Старые настройки OpenAI (можно оставить)
# ======================================================
OPENAI_API_KEY=ваш-openai-ключ-от-proxyapi.ru
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-4o-mini
